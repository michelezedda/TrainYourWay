# Get your free Groq API key at: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# Get your InstantDB App ID at: https://instantdb.com/dash (create a new app)
VITE_INSTANTDB_APP_ID=your_instantdb_app_id_here

# Support ticket email — where submitted tickets are sent
VITE_SUPPORT_EMAIL=your@email.com

# EmailJS (optional) — enables direct in-app email sending without opening an email client
# Sign up free at https://www.emailjs.com, create a service + template, then paste the IDs below
# Template variables to use: {{category}}, {{description}}, {{kai_summary}}, {{user_id}}, {{has_screenshot}}, {{screenshot_url}}
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key
